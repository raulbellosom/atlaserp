{
  "servers": {
    "supabase": {
      "type": "http",
      "url": "https://supabase.racoondevs.com/mcp?features=docs%2Cdatabase%2Cdebugging%2Cdevelopment",
      "headers": {
        "Authorization": "Bearer ${input:supabaseServiceKey}"
      }
    }
  },
  "inputs": [
    {
      "id": "supabaseServiceKey",
      "type": "promptString",
      "description": "Supabase Service Role Key — from VPS at /opt/supabase-atlaserp/supabase/docker/.env (SERVICE_ROLE_KEY)",
      "password": true
    }
  ]
}
