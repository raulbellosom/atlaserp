model FleetDriverDocument {
  id           String   @id @default(uuid(7)) @db.Uuid
  companyId    String   @db.Uuid @map("company_id")
  driverId     String   @db.Uuid @map("driver_id")
  fileAssetId  String?  @db.Uuid @map("file_asset_id")
  documentType String?  @map("document_type")
  label        String?
  enabled      Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([companyId, driverId])
  @@index([companyId, fileAssetId])
  @@map("fleet_driver_document")
}

model FleetReport {
  id                     String    @id @default(uuid(7)) @db.Uuid
  companyId              String    @db.Uuid @map("company_id")
  vehicleId              String?   @db.Uuid @map("vehicle_id")
  reportType             String    @map("report_type")
  folio                  String?
  status                 String    @default("draft")
  title                  String?
  reportDate             DateTime  @map("report_date") @db.Date
  odometerKm             Int?      @map("odometer_km")
  isInhouseWorkshop      Boolean   @default(true) @map("is_inhouse_workshop")
  workshopName           String?   @map("workshop_name")
  workshopPhone          String?   @map("workshop_phone")
  workshopAddress        String?   @map("workshop_address")
  invoiceNumber          String?   @map("invoice_number")
  laborCost              Decimal?  @db.Decimal(10, 2) @map("labor_cost")
  partsCost              Decimal?  @db.Decimal(10, 2) @map("parts_cost")
  totalCost              Decimal?  @db.Decimal(10, 2) @map("total_cost")
  notes                  String?
  finalizedAt            DateTime? @map("finalized_at")
  finalizedByProfileId   String?   @db.Uuid @map("finalized_by_profile_id")
  maintenanceSubtype     String?   @map("maintenance_subtype")
  nextServiceDate        DateTime? @map("next_service_date") @db.Date
  nextServiceOdometer    Int?      @map("next_service_odometer")
  serviceSubtype         String?   @map("service_subtype")
  repairPriority         String?   @map("repair_priority")
  repairDamageType       String?   @map("repair_damage_type")
  repairStartDate        DateTime? @map("repair_start_date") @db.Date
  repairCompletionDate   DateTime? @map("repair_completion_date") @db.Date
  repairEstimatedCost    Decimal?  @db.Decimal(10, 2) @map("repair_estimated_cost")
  warrantyDays           Int?      @map("warranty_days")
  warrantyNotes          String?   @map("warranty_notes")
  otherCategoryLabel     String?   @map("other_category_label")
  enabled                Boolean   @default(true)
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  @@unique([companyId, folio])
  @@index([companyId, vehicleId])
  @@index([companyId, reportType])
  @@index([companyId, status])
  @@index([companyId, reportDate])
  @@map("fleet_report")
}

model FleetReportPart {
  id        String   @id @default(uuid(7)) @db.Uuid
  companyId String   @db.Uuid @map("company_id")
