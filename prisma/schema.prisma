generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ModuleKind {
  CORE
  FEATURE
  INTEGRATION
  WEBSITE
  @@map("module_kind")
}

enum ModuleStatus {
  INSTALLED
  DISABLED
  UNINSTALLED
  ERROR
  @@map("module_status")
}

enum BlueprintKind {
  ENTITY
  FORM
  TABLE
  DASHBOARD
  ACTION
  RELATION
  PERMISSION
  @@map("blueprint_kind")
}

enum FileVisibility {
  PRIVATE
  INTERNAL
  PUBLIC
  @@map("file_visibility")
}

model AtlasModule {
  id String @id @default(uuid(7)) @db.Uuid
  key            String   @unique
  name           String
  description    String?
  version        String
  kind           ModuleKind @default(FEATURE)
  status         ModuleStatus @default(INSTALLED)
  core           Boolean  @default(false)
  uninstallable  Boolean  @default(true)
  enabled        Boolean  @default(true)
  manifest       Json
  lifecycleConfig Json? @map("lifecycle_config")
  installedAt DateTime @default(now()) @map("installed_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  hasBundle  Boolean  @default(false) @map("has_bundle")
  bundleHash String?  @map("bundle_hash")

  dependencies   ModuleDependency[] @relation("ModuleDependencies")
  requiredBy     ModuleDependency[] @relation("RequiredByModules")
  blueprints     Blueprint[]
  permissions    Permission[]

  @@index([status, enabled])
  @@map("atlas_module")
}

model ModuleDependency {
  id String @id @default(uuid(7)) @db.Uuid
  moduleId String @db.Uuid @map("module_id")
  dependencyId String @db.Uuid @map("dependency_id")
  versionRange String? @map("version_range")
  optional       Boolean @default(false)

  module         AtlasModule @relation("ModuleDependencies", fields: [moduleId], references: [id], onDelete: Cascade)
  dependency     AtlasModule @relation("RequiredByModules", fields: [dependencyId], references: [id], onDelete: Restrict)

  @@unique([moduleId, dependencyId])
  @@map("module_dependency")
}

model Blueprint {
  id String @id @default(uuid(7)) @db.Uuid
  key         String @unique
  moduleId String @db.Uuid @map("module_id")
  kind        BlueprintKind
  version     String
  schema      Json
  enabled     Boolean @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  module      AtlasModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@index([moduleId])
  @@index([enabled])
  @@map("blueprint")
}

model AtlasModel {
  id String @id @default(uuid(7)) @db.Uuid
  moduleKey String @map("module_key")
  name          String @unique
  tableName String @unique @map("table_name")
  label         String
  pluralLabel String? @map("plural_label")
  companyScoped Boolean @default(true) @map("company_scoped")
  schema        Json
  enabled       Boolean @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  fields        AtlasField[]
  views         AtlasView[]

  @@index([moduleKey])
  @@map("atlas_model")
}

model AtlasField {
  id String @id @default(uuid(7)) @db.Uuid
  modelId String @db.Uuid @map("model_id")
  name         String
  label        String
  type         String
  required     Boolean @default(false)
  readonly     Boolean @default(false)
  defaultValue Json? @map("default_value")
  options      Json?
  relation     Json?
  validation   Json?
  order        Int @default(0)

  model        AtlasModel @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@unique([modelId, name])
  @@map("atlas_field")
}

model AtlasView {
  id String @id @default(uuid(7)) @db.Uuid
  moduleKey String @map("module_key")
  key        String @unique
  modelName String? @map("model_name")
  type       String
  title      String?
  schema     Json
  enabled    Boolean @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  model      AtlasModel? @relation(fields: [modelName], references: [name], onDelete: SetNull, onUpdate: Cascade)

  @@index([moduleKey])
  @@index([modelName])
  @@map("atlas_view")
}

model ModuleMigration {
  id String @id @default(uuid(7)) @db.Uuid
  moduleKey String @map("module_key")
  filename  String
  checksum  String
  appliedAt DateTime @default(now()) @map("applied_at")

  @@unique([moduleKey, filename])
  @@map("module_migration")
}

model Company {
  id String @id @default(uuid(7)) @db.Uuid
  name           String
  slug           String          @unique
  legalName String? @map("legal_name")
  rfc            String?
  companyType String? @map("company_type")
  companyTypeName String? @map("company_type_name")
  industryKey String? @map("industry_key")
  industryName String? @map("industry_name")
  companySize String? @map("company_size")
  contactEmail String? @map("contact_email")
  phone          String?
  website        String?
  country        String?
  state          String?
  city           String?
  colony         String?
  street         String?
  extNumber String? @map("ext_number")
  intNumber String? @map("int_number")
  postalCode String? @map("postal_code")
  enabled        Boolean         @default(true)
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  memberships    Membership[]
  brandingConfig BrandingConfig?

  hrEmployees    HrEmployee[]
  hrDepartments  HrDepartment[]
  hrJobTitles    HrJobTitle[]

  @@map("company")
}

model UserProfile {
  id String @id @default(uuid(7)) @db.Uuid
  authUserId String @unique @db.Uuid @map("auth_user_id")
  displayName String @map("display_name")
  firstName String   @default("") @map("first_name")
  lastName String   @default("") @map("last_name")
  email        String   @unique
  avatarFileId String? @db.Uuid @map("avatar_file_id")
  birthDate DateTime? @map("birth_date")
  gender       String?
  phone        String?
  country      String?
  state        String?
  city         String?
  colony       String?
  street       String?
  extNumber String? @map("ext_number")
  intNumber String? @map("int_number")
  postalCode String? @map("postal_code")
  bio          String?
  enabled      Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  memberships  Membership[]
  auditLogs    AuditLog[]
  notifications Notification[]

  hrEmployee HrEmployee?
  tablePreferences UserTablePreference[]
  preferences  UserPreference[]

  calendarOwner          CalendarCalendar[]       @relation("CalendarOwner")
  calendarShares         CalendarShare[]          @relation("CalendarShareUser")
  calendarAttendees      CalendarEventAttendee[]  @relation("CalendarAttendee")
  calendarReminders      CalendarReminder[]       @relation("CalendarReminder")
  calendarNotifications  CalendarNotification[]   @relation("CalendarNotificationUser")

  @@map("user_profile")
}

model UserTablePreference {
  id String @id @default(uuid(7)) @db.Uuid
  userId String @db.Uuid @map("user_id")
  tableKey String @map("table_key")
  config    Json
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  user      UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tableKey])
  @@index([userId])
  @@map("user_table_preference")
}

model Membership {
  id String @id @default(uuid(7)) @db.Uuid
  companyId String @db.Uuid @map("company_id")
  userId String @db.Uuid @map("user_id")
  roleId String? @db.Uuid @map("role_id")
  enabled     Boolean @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user        UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        Role? @relation(fields: [roleId], references: [id], onDelete: SetNull)

  @@unique([companyId, userId])
  @@index([userId, enabled])
  @@index([companyId])
  @@map("membership")
}

model Role {
  id String @id @default(uuid(7)) @db.Uuid
  key         String @unique
  name        String
  description String?
  system      Boolean @default(false)
  enabled     Boolean @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  memberships Membership[]
  permissions RolePermission[]
  @@map("role")
}

model Permission {
  id String @id @default(uuid(7)) @db.Uuid
  key         String @unique
  name        String
  moduleId String? @db.Uuid @map("module_id")
  moduleKey String? @map("module_key")
  description String?
  active      Boolean @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  module      AtlasModule? @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  roles       RolePermission[]

  @@index([moduleId])
  @@index([active])
  @@map("permission")
}

model RolePermission {
  id String @id @default(uuid(7)) @db.Uuid
  roleId String @db.Uuid @map("role_id")
  permissionId String @db.Uuid @map("permission_id")

  role          Role @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission    Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permission")
}

model FileAsset {
  id String @id @default(uuid(7)) @db.Uuid
  bucket        String
  objectKey String @map("object_key")
  originalName String @map("original_name")
  mimeType String @map("mime_type")
  sizeBytes Int @map("size_bytes")
  checksum      String?
  visibility    FileVisibility @default(PRIVATE)
  moduleKey String? @map("module_key")
  entityType String? @map("entity_type")
  entityId String? @db.Uuid @map("entity_id")
  uploadedById String? @db.Uuid @map("uploaded_by_id")
  metadata      Json?
  enabled       Boolean @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  hrProfileEmployees HrEmployee[] @relation("HrEmployeeProfileImage")
  calendarFiles      CalendarEventFile[]

  @@index([moduleKey, entityType, entityId])
  @@map("file_asset")
}

model AuditLog {
  id String @id @default(uuid(7)) @db.Uuid
  actorId String? @db.Uuid @map("actor_id")
  moduleKey String? @map("module_key")
  entityType String? @map("entity_type")
  entityId String? @db.Uuid @map("entity_id")
  action      String
  before      Json?
  after       Json?
  metadata    Json?
  createdAt DateTime @default(now()) @map("created_at")

  actor       UserProfile? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([moduleKey, entityType, entityId])
  @@index([createdAt])
  @@map("audit_log")
}

model Contact {
  id String @id @default(uuid(7)) @db.Uuid
  companyId String? @db.Uuid @map("company_id")
  type        String
  name        String
  legalName String? @map("legal_name")
  email       String?
  phone       String?
  taxId String? @map("tax_id")
  notesMarkdown String? @map("notes_markdown")
  metadata    Json?
  enabled     Boolean @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([type])
  @@index([name])
  @@index([companyId, enabled])
  @@map("contact")
}

model HrEmployee {
  id String @id @default(uuid(7)) @db.Uuid
  companyId String @db.Uuid @map("company_id")
  userProfileId String? @unique @db.Uuid @map("user_profile_id")
  supervisorEmployeeId String? @db.Uuid @map("supervisor_employee_id")
  departmentId String? @db.Uuid @map("department_id")
  jobTitleId String? @db.Uuid @map("job_title_id")
  profileImageFileId String? @db.Uuid @map("profile_image_file_id")
  employeeCode String? @map("employee_code")
  firstName String @map("first_name")
  lastName String @map("last_name")
  workEmail String? @map("work_email")
  personalEmail String? @map("personal_email")
  phone          String?
  emergencyContactName String? @map("emergency_contact_name")
  emergencyContactPhone String? @map("emergency_contact_phone")
  jobTitle String? @map("job_title")
  department     String?
  managerName String? @map("manager_name")
  employmentType String? @map("employment_type")
  workLocation String? @map("work_location")
  hireDate DateTime? @map("hire_date")
  terminationDate DateTime? @map("termination_date")
  status         String   @default("active")
  notesMarkdown String? @map("notes_markdown")
  metadata       Json?
  enabled        Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  company        Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userProfile    UserProfile? @relation(fields: [userProfileId], references: [id], onDelete: SetNull)
  supervisor     HrEmployee? @relation("HrEmployeeSupervisor", fields: [supervisorEmployeeId], references: [id], onDelete: SetNull)
  reportees      HrEmployee[] @relation("HrEmployeeSupervisor")
  departmentRef  HrDepartment? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  jobTitleRef    HrJobTitle? @relation(fields: [jobTitleId], references: [id], onDelete: SetNull)
  profileImageFile FileAsset? @relation("HrEmployeeProfileImage", fields: [profileImageFileId], references: [id], onDelete: SetNull)

  @@index([companyId, enabled])
  @@index([companyId, lastName, firstName])
  @@index([companyId, supervisorEmployeeId])
  @@index([companyId, departmentId])
  @@index([companyId, jobTitleId])
  @@map("hr_employee")
}

model HrDepartment {
  id String @id @default(uuid(7)) @db.Uuid
  companyId String @db.Uuid @map("company_id")
  name        String
  description String?
  enabled     Boolean @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employees   HrEmployee[] @relation()

  @@unique([companyId, name])
  @@index([companyId, enabled])
  @@map("hr_department")
}

model HrJobTitle {
  id String @id @default(uuid(7)) @db.Uuid
  companyId String @db.Uuid @map("company_id")
  name        String
  description String?
  enabled     Boolean @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employees   HrEmployee[] @relation()

  @@unique([companyId, name])
  @@index([companyId, enabled])
  @@map("hr_job_title")
}

model InstanceConfig {
  id String @id @default(uuid(7)) @db.Uuid
  key       String   @unique
  value     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  @@map("instance_config")
}

model BrandingConfig {
  id String @id @default(uuid(7)) @db.Uuid
  companyId String @unique @db.Uuid @map("company_id")
  primaryColor String @map("primary_color")
  logoFileId String? @db.Uuid @map("logo_file_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  @@map("branding_config")
}

model Notification {
  id String @id @default(uuid(7)) @db.Uuid
  userId String @db.Uuid @map("user_id")
  companyId String? @db.Uuid @map("company_id")
  kind      String    @default("info")
  title     String
  body      String?
  link      String?
  readAt DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user      UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([createdAt])
  @@map("notification")
}

model UserPreference {
  id String @id @default(uuid(7)) @db.Uuid
  userId String @db.Uuid @map("user_id")
  key       String
  value     Json
  updatedAt DateTime    @updatedAt @map("updated_at")

  user      UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId])
  @@map("user_preference")
}

// ─── atlas.website ────────────────────────────────────────────────────────────

model WebsiteSite {
  id             String    @id @default(uuid(7)) @db.Uuid
  companyId      String    @db.Uuid @map("company_id")
  name           String
  domain         String?
  defaultLocale  String    @default("es") @map("default_locale")
  status         String    @default("draft")
  homepagePageId String?   @db.Uuid @map("homepage_page_id")
  themeId        String?   @db.Uuid @map("theme_id")
  settings       Json?
  seoDefaults    Json?     @map("seo_defaults")
  enabled        Boolean   @default(true)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@index([companyId, enabled])
  @@map("website_site")
}

model WebsitePage {
  id                   String    @id @default(uuid(7)) @db.Uuid
  companyId            String    @db.Uuid @map("company_id")
  siteId               String    @db.Uuid @map("site_id")
  title                String
  slug                 String
  routePath            String    @map("route_path")
  status               String    @default("draft")
  pageType             String    @default("page") @map("page_type")
  draftBuilderData     Json?     @map("draft_builder_data")
  publishedBuilderData Json?     @map("published_builder_data")
  seo                  Json?
  visibility           String    @default("public")
  publishedAt          DateTime? @map("published_at")
  createdById          String?   @db.Uuid @map("created_by_id")
  updatedById          String?   @db.Uuid @map("updated_by_id")
  enabled              Boolean   @default(true)
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  @@unique([companyId, siteId, routePath])
  @@index([companyId, status])
  @@map("website_page")
}

model WebsitePageVersion {
  id            String   @id @default(uuid(7)) @db.Uuid
  companyId     String   @db.Uuid @map("company_id")
  pageId        String   @db.Uuid @map("page_id")
  versionNumber Int      @map("version_number")
  builderData   Json?    @map("builder_data")
  seo           Json?
  status        String   @default("snapshot")
  createdById   String?  @db.Uuid @map("created_by_id")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([pageId])
  @@map("website_page_version")
}

model WebsiteTheme {
  id         String   @id @default(uuid(7)) @db.Uuid
  companyId  String   @db.Uuid @map("company_id")
  siteId     String   @db.Uuid @map("site_id")
  name       String
  tokens     Json?
  typography Json?
  layout     Json?
  customCss  String?  @map("custom_css")
  isDefault  Boolean  @default(false) @map("is_default")
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([companyId, siteId, enabled])
  @@map("website_theme")
}

model WebsiteMenu {
  id        String   @id @default(uuid(7)) @db.Uuid
  companyId String   @db.Uuid @map("company_id")
  siteId    String   @db.Uuid @map("site_id")
  name      String
  location  String   @default("header")
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([companyId, siteId, enabled])
  @@map("website_menu")
}

model WebsiteMenuItem {
  id        String   @id @default(uuid(7)) @db.Uuid
  companyId String   @db.Uuid @map("company_id")
  menuId    String   @db.Uuid @map("menu_id")
  parentId  String?  @db.Uuid @map("parent_id")
  label     String
  url       String?
  pageId    String?  @db.Uuid @map("page_id")
  target    String   @default("_self")
  icon      String?
  sortOrder Int      @default(0) @map("sort_order")
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([menuId, enabled])
  @@map("website_menu_item")
}

model WebsitePublishedRender {
  id          String    @id @default(uuid(7)) @db.Uuid
  companyId   String    @db.Uuid @map("company_id")
  siteId      String    @db.Uuid @map("site_id")
  sourceType  String    @map("source_type")
  sourceId    String    @db.Uuid @map("source_id")
  path        String
  html        String?
  title       String?
  description String?
  ogImage     String?   @map("og_image")
  statusCode  Int       @default(200) @map("status_code")
  contentHash String?   @map("content_hash")
  publishedAt DateTime? @map("published_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@unique([siteId, path])
  @@index([companyId, siteId])
  @@map("website_published_render")
}

model WebsiteBlogCategory {
  id          String   @id @default(uuid(7)) @db.Uuid
  companyId   String   @db.Uuid @map("company_id")
  siteId      String   @db.Uuid @map("site_id")
  name        String
  slug        String
  description String?
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  posts WebsiteBlogPost[]

  @@unique([companyId, siteId, slug])
  @@index([companyId, siteId, enabled])
  @@map("website_blog_category")
}

model WebsiteBlogPost {
  id                   String    @id @default(uuid(7)) @db.Uuid
  companyId            String    @db.Uuid @map("company_id")
  siteId               String    @db.Uuid @map("site_id")
  categoryId           String?   @db.Uuid @map("category_id")
  title                String
  slug                 String
  excerpt              String?
  featuredImage        String?   @map("featured_image")
  status               String    @default("draft")
  draftBuilderData     Json?     @map("draft_builder_data")
  publishedBuilderData Json?     @map("published_builder_data")
  seo                  Json?
  publishedAt          DateTime? @map("published_at")
  createdById          String?   @db.Uuid @map("created_by_id")
  updatedById          String?   @db.Uuid @map("updated_by_id")
  enabled              Boolean   @default(true)
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  category WebsiteBlogCategory? @relation(fields: [categoryId], references: [id])

  @@unique([companyId, siteId, slug])
  @@index([companyId, siteId, status, enabled])
  @@map("website_blog_post")
}

model WebsiteForm {
  id             String   @id @default(uuid(7)) @db.Uuid
  companyId      String   @db.Uuid @map("company_id")
  siteId         String   @db.Uuid @map("site_id")
  name           String
  description    String?
  submitLabel    String   @default("Enviar") @map("submit_label")
  successMessage String?  @map("success_message")
  notifyEmail    String?  @map("notify_email")
  enabled        Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  fields      WebsiteFormField[]
  submissions WebsiteFormSubmission[]

  @@index([companyId, siteId, enabled])
  @@map("website_form")
}

model WebsiteFormField {
  id          String   @id @default(uuid(7)) @db.Uuid
  companyId   String   @db.Uuid @map("company_id")
  formId      String   @db.Uuid @map("form_id")
  label       String
  name        String
  fieldType   String   @default("text") @map("field_type")
  placeholder String?
  required    Boolean  @default(false)
  options     Json?
  sortOrder   Int      @default(0) @map("sort_order")
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  form WebsiteForm @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([formId, enabled])
  @@map("website_form_field")
}

model WebsiteFormSubmission {
  id          String   @id @default(uuid(7)) @db.Uuid
  companyId   String   @db.Uuid @map("company_id")
  formId      String   @db.Uuid @map("form_id")
  data        Json
  submitterIp String?  @map("submitter_ip")
  submittedAt DateTime @default(now()) @map("submitted_at")

  form WebsiteForm @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([formId, submittedAt])
  @@map("website_form_submission")
}

// ─── atlas.ledger ─────────────────────────────────────────────────────────────

model LedgerAccount {
  id             String   @id @default(uuid(7)) @db.Uuid
  companyId      String   @db.Uuid @map("company_id")
  name           String
  bank           String
  accountNumber  String?  @map("account_number")
  currency       String   @default("MXN")
  openingBalance Decimal  @default(0) @db.Decimal(15, 2) @map("opening_balance")
  enabled        Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@unique([companyId, name])
  @@index([companyId, enabled])
  @@map("ledger_account")
}

model LedgerCategory {
  id        String   @id @default(uuid(7)) @db.Uuid
  companyId String   @db.Uuid @map("company_id")
  name      String
  color     String?
  kind      String   @default("both")
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([companyId, name])
  @@index([companyId, enabled])
  @@map("ledger_category")
}

model LedgerTransaction {
  id         String   @id @default(uuid(7)) @db.Uuid
  companyId  String   @db.Uuid @map("company_id")
  accountId  String   @db.Uuid @map("account_id")
  categoryId String?  @db.Uuid @map("category_id")
  tipoId     String?  @db.Uuid @map("tipo_id")
  fecha      DateTime @db.Date
  numero     String?
  nombre     String
  referencia String?
  concepto   String?
  deposito   Decimal? @db.Decimal(15, 2)
  retiro     Decimal? @db.Decimal(15, 2)
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([accountId, enabled])
  @@index([companyId, fecha])
  @@index([accountId, fecha])
  @@map("ledger_transaction")
}

model LedgerTransactionType {
  id        String   @id @default(uuid(7)) @db.Uuid
  companyId String   @db.Uuid @map("company_id")
  code      String
  name      String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([companyId, code])
  @@index([companyId, enabled])
  @@map("ledger_transaction_type")
}

// ─── atlas.fleet ──────────────────────────────────────────────────────────────

model FleetVehicleType {
  id                   String   @id @default(uuid(7)) @db.Uuid
  companyId            String   @db.Uuid @map("company_id")
  name                 String
  description          String?
  economicGroupNumber  String?  @map("economic_group_number")
  enabled              Boolean  @default(true)
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@index([companyId, enabled])
  @@map("fleet_vehicle_type")
}

model FleetVehicleBrand {
  id        String   @id @default(uuid(7)) @db.Uuid
  companyId String   @db.Uuid @map("company_id")
  name      String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([companyId, enabled])
  @@map("fleet_vehicle_brand")
}

model FleetVehicleModel {
  id        String   @id @default(uuid(7)) @db.Uuid
  companyId String   @db.Uuid @map("company_id")
  brandId   String   @db.Uuid @map("brand_id")
  typeId    String?  @db.Uuid @map("type_id")
  name      String
  year      Int?
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([companyId, brandId, typeId, name, year])
  @@index([companyId, brandId])
  @@index([companyId, typeId])
  @@index([companyId, enabled])
  @@map("fleet_vehicle_model")
}

model FleetVehicle {
  id                       String    @id @default(uuid(7)) @db.Uuid
  companyId                String    @db.Uuid @map("company_id")
  plate                    String
  brand                    String?
  modelName                String?   @map("model_name")
  year                     Int?
  vehicleTypeId            String?   @db.Uuid @map("vehicle_type_id")
  vehicleBrandId           String?   @db.Uuid @map("vehicle_brand_id")
  vehicleModelId           String?   @db.Uuid @map("vehicle_model_id")
  economicGroupNumber      String?   @map("economic_group_number")
  economicIndividualNumber String?   @map("economic_individual_number")
  color                    String?
  status                   String    @default("active")
  driverId                 String?   @db.Uuid @map("driver_id")
  photoAssetId             String?   @db.Uuid @map("photo_asset_id")
  notes                    String?
  isFinanced               Boolean   @default(false) @map("is_financed")
  financingInstitution     String?   @map("financing_institution")
  financingContractNumber  String?   @map("financing_contract_number")
  financingStartDate       DateTime? @map("financing_start_date") @db.Date
  financingEndDate         DateTime? @map("financing_end_date") @db.Date
  financingMonthlyPayment  Decimal?  @db.Decimal(10, 2) @map("financing_monthly_payment")
  financingNotes           String?   @map("financing_notes")
  enabled                  Boolean   @default(true)
  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime  @updatedAt @map("updated_at")

  @@unique([companyId, plate])
  @@index([companyId, status])
  @@index([companyId, vehicleModelId])
  @@index([companyId, vehicleTypeId])
  @@index([companyId, vehicleBrandId])
  @@map("fleet_vehicle")
}

model FleetVehicleDocument {
  id           String   @id @default(uuid(7)) @db.Uuid
  companyId    String   @db.Uuid @map("company_id")
  vehicleId    String   @db.Uuid @map("vehicle_id")
  fileAssetId  String?  @db.Uuid @map("file_asset_id")
  documentType String?  @map("document_type")
  label        String?
  enabled      Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([companyId, vehicleId])
  @@index([companyId, fileAssetId])
  @@map("fleet_vehicle_document")
}

model FleetDriver {
  id               String    @id @default(uuid(7)) @db.Uuid
  companyId        String    @db.Uuid @map("company_id")
  firstName        String    @map("first_name")
  lastName         String    @map("last_name")
  phone            String
  email            String?
  photoAssetId     String?   @db.Uuid @map("photo_asset_id")
  hrEmployeeId     String?   @db.Uuid @map("hr_employee_id")
  licenseNumber    String    @map("license_number")
  licenseType      String?   @map("license_type")
  licenseExpiryDate DateTime? @map("license_expiry_date") @db.Date
  status           String    @default("active")
  notes            String?
  enabled          Boolean   @default(true)
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@unique([companyId, licenseNumber])
  @@index([companyId, enabled])
  @@map("fleet_driver")
}

model FleetDriverDocument {
  id           String   @id @default(uuid(7)) @db.Uuid
  companyId    String   @db.Uuid @map("company_id")
  driverId     String   @db.Uuid @map("driver_id")
  fileAssetId  String?  @db.Uuid @map("file_asset_id")
  documentType String?  @map("document_type")
  label        String?
  enabled      Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([companyId, driverId])
  @@index([companyId, fileAssetId])
  @@map("fleet_driver_document")
}

model FleetReport {
  id                     String    @id @default(uuid(7)) @db.Uuid
  companyId              String    @db.Uuid @map("company_id")
  vehicleId              String?   @db.Uuid @map("vehicle_id")
  reportType             String    @map("report_type")
  folio                  String?
  status                 String    @default("draft")
  title                  String?
  reportDate             DateTime  @map("report_date") @db.Date
  odometerKm             Int?      @map("odometer_km")
  isInhouseWorkshop      Boolean   @default(true) @map("is_inhouse_workshop")
  workshopName           String?   @map("workshop_name")
  workshopPhone          String?   @map("workshop_phone")
  workshopAddress        String?   @map("workshop_address")
  invoiceNumber          String?   @map("invoice_number")
  laborCost              Decimal?  @db.Decimal(10, 2) @map("labor_cost")
  partsCost              Decimal?  @db.Decimal(10, 2) @map("parts_cost")
  totalCost              Decimal?  @db.Decimal(10, 2) @map("total_cost")
  notes                  String?
  finalizedAt            DateTime? @map("finalized_at")
  finalizedByProfileId   String?   @db.Uuid @map("finalized_by_profile_id")
  maintenanceSubtype     String?   @map("maintenance_subtype")
  nextServiceDate        DateTime? @map("next_service_date") @db.Date
  nextServiceOdometer    Int?      @map("next_service_odometer")
  serviceSubtype         String?   @map("service_subtype")
  repairPriority         String?   @map("repair_priority")
  repairDamageType       String?   @map("repair_damage_type")
  repairStartDate        DateTime? @map("repair_start_date") @db.Date
  repairCompletionDate   DateTime? @map("repair_completion_date") @db.Date
  repairEstimatedCost    Decimal?  @db.Decimal(10, 2) @map("repair_estimated_cost")
  warrantyDays           Int?      @map("warranty_days")
  warrantyNotes          String?   @map("warranty_notes")
  otherCategoryLabel     String?   @map("other_category_label")
  enabled                Boolean   @default(true)
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  @@unique([companyId, folio])
  @@index([companyId, vehicleId])
  @@index([companyId, reportType])
  @@index([companyId, status])
  @@index([companyId, reportDate])
  @@map("fleet_report")
}

model FleetReportPart {
  id        String   @id @default(uuid(7)) @db.Uuid
  companyId String   @db.Uuid @map("company_id")
  reportId  String   @db.Uuid @map("report_id")
  name      String
  quantity  Int      @default(1)
  unitCost  Decimal? @db.Decimal(10, 2) @map("unit_cost")
  subtotal  Decimal? @db.Decimal(10, 2)
  notes     String?
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([companyId, reportId])
  @@map("fleet_report_part")
}

model FleetReportDocument {
  id           String   @id @default(uuid(7)) @db.Uuid
  companyId    String   @db.Uuid @map("company_id")
  reportId     String   @db.Uuid @map("report_id")
  fileAssetId  String?  @db.Uuid @map("file_asset_id")
  documentType String?  @map("document_type")
  label        String?
  enabled      Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([companyId, reportId])
  @@index([companyId, fileAssetId])
  @@map("fleet_report_document")
}

model FleetInsurancePolicy {
  id               String    @id @default(uuid(7)) @db.Uuid
  companyId        String    @db.Uuid @map("company_id")
  vehicleId        String?   @db.Uuid @map("vehicle_id")
  insurerName      String    @map("insurer_name")
  policyNumber     String    @map("policy_number")
  coverageType     String?   @map("coverage_type")
  startDate        DateTime? @map("start_date") @db.Date
  expiryDate       DateTime? @map("expiry_date") @db.Date
  premium          Decimal?  @db.Decimal(10, 2)
  currency         String?   @default("MXN")
  notes            String?
  documentAssetId  String?   @db.Uuid @map("document_asset_id")
  enabled          Boolean   @default(true)
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@unique([companyId, policyNumber])
  @@index([companyId, vehicleId])
  @@index([companyId, expiryDate])
  @@map("fleet_insurance_policy")
}

// ── Atlas Calendar ────────────────────────────────────────────────────────────

enum CalendarShareRole {
  VIEWER
  EDITOR
  MANAGER
  @@map("calendar_share_role")
}

enum CalendarAttendeeStatus {
  PENDING
  ACCEPTED
  DECLINED
  @@map("calendar_attendee_status")
}

model CalendarCalendar {
  id        String   @id @default(uuid(7)) @db.Uuid
  ownerId   String   @db.Uuid @map("owner_id")
  name      String
  color     String   @default("#6B46C1")
  icon      String?
  isDefault Boolean  @default(false) @map("is_default")
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  owner  UserProfile     @relation("CalendarOwner", fields: [ownerId], references: [id])
  shares CalendarShare[]
  events CalendarEvent[]

  @@index([ownerId])
  @@map("calendar_calendar")
}

model CalendarShare {
  id         String            @id @default(uuid(7)) @db.Uuid
  calendarId String            @db.Uuid @map("calendar_id")
  userId     String            @db.Uuid @map("user_id")
  role       CalendarShareRole @default(VIEWER)
  createdAt  DateTime          @default(now()) @map("created_at")

  calendar CalendarCalendar @relation(fields: [calendarId], references: [id], onDelete: Cascade)
  user     UserProfile      @relation("CalendarShareUser", fields: [userId], references: [id])

  @@unique([calendarId, userId])
  @@map("calendar_share")
}

model CalendarEvent {
  id             String    @id @default(uuid(7)) @db.Uuid
  calendarId     String    @db.Uuid @map("calendar_id")
  title          String
  description    String?
  startAt        DateTime  @map("start_at")
  endAt          DateTime? @map("end_at")
  allDay         Boolean   @default(false) @map("all_day")
  location       String?
  videoUrl       String?   @map("video_url")
  color          String?
  recurrenceRule Json?     @map("recurrence_rule")
  sourceModule   String?   @map("source_module")
  sourceEntityId String?   @db.Uuid @map("source_entity_id")
  enabled        Boolean   @default(true)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  calendar      CalendarCalendar        @relation(fields: [calendarId], references: [id], onDelete: Cascade)
  attendees     CalendarEventAttendee[]
  reminders     CalendarReminder[]
  notifications CalendarNotification[]
  files         CalendarEventFile[]

  @@index([calendarId])
  @@index([startAt])
  @@index([sourceModule, sourceEntityId])
  @@map("calendar_event")
}

model CalendarEventFile {
  id          String   @id @default(uuid(7)) @db.Uuid
  eventId     String   @db.Uuid @map("event_id")
  fileAssetId String   @db.Uuid @map("file_asset_id")
  createdAt   DateTime @default(now()) @map("created_at")

  event     CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  fileAsset FileAsset     @relation(fields: [fileAssetId], references: [id])

  @@unique([eventId, fileAssetId])
  @@map("calendar_event_file")
}

model CalendarEventAttendee {
  id        String                 @id @default(uuid(7)) @db.Uuid
  eventId   String                 @db.Uuid @map("event_id")
  userId    String                 @db.Uuid @map("user_id")
  status    CalendarAttendeeStatus @default(PENDING)
  createdAt DateTime               @default(now()) @map("created_at")

  event CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  UserProfile   @relation("CalendarAttendee", fields: [userId], references: [id])

  @@unique([eventId, userId])
  @@map("calendar_event_attendee")
}

model CalendarReminder {
  id            String    @id @default(uuid(7)) @db.Uuid
  eventId       String    @db.Uuid @map("event_id")
  userId        String    @db.Uuid @map("user_id")
  minutesBefore Int       @map("minutes_before")
  sentAt        DateTime? @map("sent_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  event CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  UserProfile   @relation("CalendarReminder", fields: [userId], references: [id])

  @@unique([eventId, userId, minutesBefore])
  @@map("calendar_reminder")
}

model CalendarNotification {
  id        String    @id @default(uuid(7)) @db.Uuid
  userId    String    @db.Uuid @map("user_id")
  eventId   String    @db.Uuid @map("event_id")
  type      String    @default("REMINDER")
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user  UserProfile   @relation("CalendarNotificationUser", fields: [userId], references: [id])
  event CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@map("calendar_notification")
}

