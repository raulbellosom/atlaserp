generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ModuleKind {
  CORE
  FEATURE
  INTEGRATION
  WEBSITE
}

enum ModuleStatus {
  INSTALLED
  DISABLED
  UNINSTALLED
  ERROR
}

enum BlueprintKind {
  ENTITY
  FORM
  TABLE
  DASHBOARD
  ACTION
  RELATION
  PERMISSION
}

enum FileVisibility {
  PRIVATE
  INTERNAL
  PUBLIC
}

enum FinanceDocumentDirection {
  AR
  AP
}

enum FinanceDocumentType {
  INVOICE
  CREDIT_NOTE
  DEBIT_NOTE
  ADVANCE
  PAYMENT
}

enum FinanceDocumentStatus {
  OPEN
  PARTIAL
  PAID
  VOID
}

enum FinanceTaxKind {
  TRANSFER
  WITHHOLDING
}

enum FinanceDocumentEventType {
  ISSUE
  APPLY
  REVERSE
  VOID
  ADJUST
}

enum FinanceApplicationStatus {
  APPLIED
  REVERSED
}

model AtlasModule {
  id             String   @id @default(cuid())
  key            String   @unique
  name           String
  description    String?
  version        String
  kind           ModuleKind @default(FEATURE)
  status         ModuleStatus @default(INSTALLED)
  core           Boolean  @default(false)
  uninstallable  Boolean  @default(true)
  enabled        Boolean  @default(true)
  manifest       Json
  installedAt    DateTime @default(now())
  updatedAt      DateTime @updatedAt

  dependencies   ModuleDependency[] @relation("ModuleDependencies")
  requiredBy     ModuleDependency[] @relation("RequiredByModules")
  blueprints     Blueprint[]
  permissions    Permission[]
}

model ModuleDependency {
  id             String @id @default(cuid())
  moduleId       String
  dependencyId   String
  versionRange   String?
  optional       Boolean @default(false)

  module         AtlasModule @relation("ModuleDependencies", fields: [moduleId], references: [id], onDelete: Cascade)
  dependency     AtlasModule @relation("RequiredByModules", fields: [dependencyId], references: [id], onDelete: Restrict)

  @@unique([moduleId, dependencyId])
}

model Blueprint {
  id          String @id @default(cuid())
  key         String @unique
  moduleId    String
  kind        BlueprintKind
  version     String
  schema      Json
  enabled     Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  module      AtlasModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
}

model Company {
  id             String          @id @default(cuid())
  name           String
  slug           String          @unique
  legalName      String?
  rfc            String?
  companyType    String?
  companyTypeName String?
  industryKey    String?
  industryName   String?
  companySize    String?
  contactEmail   String?
  phone          String?
  website        String?
  country        String?
  state          String?
  city           String?
  street         String?
  extNumber      String?
  intNumber      String?
  postalCode     String?
  enabled        Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  memberships    Membership[]
  brandingConfig BrandingConfig?
  financeAccounts FinanceAccount[]
  financeEntries  FinanceJournalEntry[]
  financeFxRates  FinanceFxRate[]
  financeDocuments FinanceDocument[]
  financeDocumentApplications FinanceDocumentApplication[]
  financeDocumentAccountingLinks FinanceDocumentAccountingLink[]
  financeTaxRates FinanceTaxRate[]
  financeDocumentTaxLines FinanceDocumentTaxLine[]
  hrEmployees    HrEmployee[]
  hrDepartments  HrDepartment[]
  hrJobTitles    HrJobTitle[]
}

model UserProfile {
  id           String   @id @default(cuid())
  authUserId   String   @unique
  displayName  String
  firstName    String   @default("")
  lastName     String   @default("")
  email        String   @unique
  avatarFileId String?
  birthDate    DateTime?
  gender       String?
  phone        String?
  country      String?
  state        String?
  city         String?
  street       String?
  extNumber    String?
  intNumber    String?
  postalCode   String?
  bio          String?
  enabled      Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships  Membership[]
  auditLogs    AuditLog[]
  notifications Notification[]
  reversedFinanceApplications FinanceDocumentApplication[] @relation("FinanceDocumentApplicationReversedBy")
  hrEmployee HrEmployee?
}

model Membership {
  id          String @id @default(cuid())
  companyId   String
  userId      String
  roleId      String?
  enabled     Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user        UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        Role? @relation(fields: [roleId], references: [id], onDelete: SetNull)

  @@unique([companyId, userId])
}

model Role {
  id          String @id @default(cuid())
  key         String @unique
  name        String
  description String?
  system      Boolean @default(false)
  enabled     Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  memberships Membership[]
  permissions RolePermission[]
}

model Permission {
  id          String @id @default(cuid())
  key         String @unique
  name        String
  moduleId    String?
  description String?
  createdAt   DateTime @default(now())

  module      AtlasModule? @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  roles       RolePermission[]
}

model RolePermission {
  id            String @id @default(cuid())
  roleId        String
  permissionId  String

  role          Role @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission    Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model FileAsset {
  id            String @id @default(cuid())
  bucket        String
  objectKey     String
  originalName  String
  mimeType      String
  sizeBytes     Int
  checksum      String?
  visibility    FileVisibility @default(PRIVATE)
  moduleKey     String?
  entityType    String?
  entityId      String?
  uploadedById  String?
  metadata      Json?
  enabled       Boolean @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  hrProfileEmployees HrEmployee[] @relation("HrEmployeeProfileImage")

  @@index([moduleKey, entityType, entityId])
}

model AuditLog {
  id          String @id @default(cuid())
  actorId     String?
  moduleKey   String?
  entityType  String?
  entityId    String?
  action      String
  before      Json?
  after       Json?
  metadata    Json?
  createdAt   DateTime @default(now())

  actor       UserProfile? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([moduleKey, entityType, entityId])
  @@index([createdAt])
}

model Contact {
  id          String @id @default(cuid())
  companyId   String?
  type        String
  name        String
  legalName   String?
  email       String?
  phone       String?
  taxId       String?
  notesMarkdown String?
  metadata    Json?
  enabled     Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  financeLines FinanceJournalLine[]
  financeDocuments FinanceDocument[]

  @@index([type])
  @@index([name])
}

model HrEmployee {
  id             String   @id @default(cuid())
  companyId      String
  userProfileId  String? @unique
  supervisorEmployeeId String?
  departmentId   String?
  jobTitleId     String?
  profileImageFileId String?
  employeeCode   String?
  firstName      String
  lastName       String
  workEmail      String?
  personalEmail  String?
  phone          String?
  emergencyContactName  String?
  emergencyContactPhone String?
  jobTitle       String?
  department     String?
  managerName    String?
  employmentType String?
  workLocation   String?
  hireDate       DateTime?
  terminationDate DateTime?
  status         String   @default("active")
  notesMarkdown  String?
  metadata       Json?
  enabled        Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  company        Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userProfile    UserProfile? @relation(fields: [userProfileId], references: [id], onDelete: SetNull)
  supervisor     HrEmployee? @relation("HrEmployeeSupervisor", fields: [supervisorEmployeeId], references: [id], onDelete: SetNull)
  reportees      HrEmployee[] @relation("HrEmployeeSupervisor")
  departmentRef  HrDepartment? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  jobTitleRef    HrJobTitle? @relation(fields: [jobTitleId], references: [id], onDelete: SetNull)
  profileImageFile FileAsset? @relation("HrEmployeeProfileImage", fields: [profileImageFileId], references: [id], onDelete: SetNull)

  @@index([companyId, enabled])
  @@index([companyId, lastName, firstName])
  @@index([companyId, supervisorEmployeeId])
  @@index([companyId, departmentId])
  @@index([companyId, jobTitleId])
}

model HrDepartment {
  id          String @id @default(cuid())
  companyId   String
  name        String
  description String?
  enabled     Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employees   HrEmployee[] @relation()

  @@unique([companyId, name])
  @@index([companyId, enabled])
}

model HrJobTitle {
  id          String @id @default(cuid())
  companyId   String
  name        String
  description String?
  enabled     Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employees   HrEmployee[] @relation()

  @@unique([companyId, name])
  @@index([companyId, enabled])
}

model FinanceAccount {
  id             String @id @default(cuid())
  companyId      String
  parentAccountId String?
  code           String
  name           String
  type           String
  currency       String @default("MXN")
  initialBalance Decimal @default(0)
  metadata       Json?
  enabled        Boolean @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  company       Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parentAccount FinanceAccount? @relation("FinanceAccountHierarchy", fields: [parentAccountId], references: [id], onDelete: SetNull)
  childAccounts FinanceAccount[] @relation("FinanceAccountHierarchy")
  journalLines  FinanceJournalLine[]

  @@unique([companyId, code])
  @@index([companyId, enabled])
  @@index([companyId, type])
}

model FinanceJournalEntry {
  id          String @id @default(cuid())
  companyId   String
  createdById String?
  entryNumber String
  occurredAt  DateTime
  concept     String
  reference   String?
  currency    String @default("MXN")
  sourceType  String @default("manual")
  metadata    Json?
  enabled     Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lines       FinanceJournalLine[]
  documentLinks FinanceDocumentAccountingLink[]

  @@unique([companyId, entryNumber])
  @@index([companyId, occurredAt])
  @@index([enabled, occurredAt])
}

model FinanceJournalLine {
  id          String @id @default(cuid())
  entryId     String
  accountId   String
  contactId   String?
  debit       Decimal @default(0)
  credit      Decimal @default(0)
  currency    String @default("MXN")
  fxRate      Decimal?
  baseAmount  Decimal?
  note        String?
  metadata    Json?
  enabled     Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  entry       FinanceJournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  account     FinanceAccount @relation(fields: [accountId], references: [id], onDelete: Restrict)
  contact     Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([entryId])
  @@index([accountId])
  @@index([contactId])
}

model FinanceFxRate {
  id           String @id @default(cuid())
  companyId    String
  baseCurrency String
  quoteCurrency String
  rateDate     DateTime
  rate         Decimal
  source       String @default("manual")
  metadata     Json?
  enabled      Boolean @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company      Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, baseCurrency, quoteCurrency, rateDate])
  @@index([companyId, rateDate])
  @@index([companyId, baseCurrency, quoteCurrency])
}

model FinanceDocument {
  id            String                   @id @default(cuid())
  companyId     String
  direction     FinanceDocumentDirection
  docType       FinanceDocumentType
  status        FinanceDocumentStatus    @default(OPEN)
  contactId     String?
  currency      String                   @default("MXN")
  issueDate     DateTime
  dueDate       DateTime?
  reference     String?
  notesMarkdown String?
  totalAmount   Decimal
  openAmount    Decimal
  metadata      Json?
  enabled       Boolean                  @default(true)
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt

  company       Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact       Contact?                 @relation(fields: [contactId], references: [id], onDelete: SetNull)
  sourceApplications FinanceDocumentApplication[] @relation("FinanceDocumentApplicationSource")
  targetApplications FinanceDocumentApplication[] @relation("FinanceDocumentApplicationTarget")
  accountingLinks FinanceDocumentAccountingLink[]
  taxLines       FinanceDocumentTaxLine[]

  @@index([companyId, direction, status])
  @@index([companyId, issueDate])
  @@index([companyId, dueDate])
  @@index([contactId])
}

model FinanceTaxRate {
  id         String    @id @default(cuid())
  companyId  String
  key        String
  name       String
  kind       FinanceTaxKind
  rate       Decimal
  direction  FinanceDocumentDirection?
  metadata   Json?
  enabled    Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  company    Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  documentTaxLines FinanceDocumentTaxLine[]

  @@unique([companyId, key])
  @@index([companyId, kind])
  @@index([companyId, direction])
}

model FinanceDocumentTaxLine {
  id          String         @id @default(cuid())
  companyId   String
  documentId  String
  taxRateId   String?
  taxKey      String
  taxName     String
  kind        FinanceTaxKind
  rate        Decimal
  baseAmount  Decimal
  taxAmount   Decimal
  currency    String         @default("MXN")
  metadata    Json?
  enabled     Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  company     Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  document    FinanceDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  taxRate     FinanceTaxRate? @relation(fields: [taxRateId], references: [id], onDelete: SetNull)

  @@index([companyId, documentId])
  @@index([companyId, kind])
}

model FinanceDocumentApplication {
  id               String          @id @default(cuid())
  companyId        String
  sourceDocumentId String
  targetDocumentId String
  appliedAmount    Decimal
  status           FinanceApplicationStatus @default(APPLIED)
  effectiveFxRate  Decimal?
  sourceAmount     Decimal?
  targetAmount     Decimal?
  appliedAt        DateTime        @default(now())
  reversedAt       DateTime?
  reversedById     String?
  reversalReason   String?
  metadata         Json?
  enabled          Boolean         @default(true)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  company          Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sourceDocument   FinanceDocument @relation("FinanceDocumentApplicationSource", fields: [sourceDocumentId], references: [id], onDelete: Cascade)
  targetDocument   FinanceDocument @relation("FinanceDocumentApplicationTarget", fields: [targetDocumentId], references: [id], onDelete: Cascade)
  reversedBy       UserProfile?    @relation("FinanceDocumentApplicationReversedBy", fields: [reversedById], references: [id], onDelete: SetNull)

  @@index([companyId, appliedAt])
  @@index([companyId, sourceDocumentId])
  @@index([companyId, targetDocumentId])
  @@index([companyId, status])
}

model FinanceDocumentAccountingLink {
  id             String                   @id @default(cuid())
  companyId      String
  documentId     String
  journalEntryId String
  eventType      FinanceDocumentEventType
  metadata       Json?
  enabled        Boolean                  @default(true)
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  company        Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  document       FinanceDocument          @relation(fields: [documentId], references: [id], onDelete: Cascade)
  journalEntry   FinanceJournalEntry      @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)

  @@unique([documentId, journalEntryId, eventType])
  @@index([companyId, documentId])
  @@index([companyId, journalEntryId])
}

model InstanceConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BrandingConfig {
  id           String   @id @default(cuid())
  companyId    String   @unique
  primaryColor String
  logoFileId   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  companyId String?
  kind      String    @default("info")
  title     String
  body      String?
  link      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user      UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([createdAt])
}
