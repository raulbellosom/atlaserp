  companyId String   @db.Uuid @map("company_id")
  name      String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([companyId, enabled])
  @@map("fleet_vehicle_brand")
}

model FleetVehicleModel {
  id        String   @id @default(uuid(7)) @db.Uuid
  companyId String   @db.Uuid @map("company_id")
  brandId   String   @db.Uuid @map("brand_id")
  typeId    String?  @db.Uuid @map("type_id")
  name      String
  year      Int?
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([companyId, brandId, typeId, name, year])
  @@index([companyId, brandId])
  @@index([companyId, typeId])
  @@index([companyId, enabled])
  @@map("fleet_vehicle_model")
}

model FleetVehicle {
  id                       String    @id @default(uuid(7)) @db.Uuid
  companyId                String    @db.Uuid @map("company_id")
  plate                    String
  brand                    String?
  modelName                String?   @map("model_name")
  year                     Int?
  vehicleTypeId            String?   @db.Uuid @map("vehicle_type_id")
  vehicleBrandId           String?   @db.Uuid @map("vehicle_brand_id")
  vehicleModelId           String?   @db.Uuid @map("vehicle_model_id")
  economicGroupNumber      String?   @map("economic_group_number")
  economicIndividualNumber String?   @map("economic_individual_number")
  color                    String?
  status                   String    @default("active")
  driverId                 String?   @db.Uuid @map("driver_id")
  photoAssetId             String?   @db.Uuid @map("photo_asset_id")
  notes                    String?
  isFinanced               Boolean   @default(false) @map("is_financed")
  financingInstitution     String?   @map("financing_institution")
  financingContractNumber  String?   @map("financing_contract_number")
  financingStartDate       DateTime? @map("financing_start_date") @db.Date
  financingEndDate         DateTime? @map("financing_end_date") @db.Date
  financingMonthlyPayment  Decimal?  @db.Decimal(10, 2) @map("financing_monthly_payment")
  financingNotes           String?   @map("financing_notes")
  enabled                  Boolean   @default(true)
  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime  @updatedAt @map("updated_at")

  @@unique([companyId, plate])
  @@index([companyId, status])
  @@index([companyId, vehicleModelId])
  @@index([companyId, vehicleTypeId])
  @@index([companyId, vehicleBrandId])
  @@map("fleet_vehicle")
}

model FleetVehicleDocument {
  id           String   @id @default(uuid(7)) @db.Uuid
  companyId    String   @db.Uuid @map("company_id")
  vehicleId    String   @db.Uuid @map("vehicle_id")
  fileAssetId  String?  @db.Uuid @map("file_asset_id")
  documentType String?  @map("document_type")
  label        String?
  enabled      Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([companyId, vehicleId])
  @@index([companyId, fileAssetId])
  @@map("fleet_vehicle_document")
}

model FleetDriver {
