generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ModuleKind {
  CORE
  FEATURE
  INTEGRATION
  WEBSITE
  @@map("module_kind")
}

enum ModuleStatus {
  INSTALLED
  DISABLED
  UNINSTALLED
  ERROR
  @@map("module_status")
}

enum BlueprintKind {
  ENTITY
  FORM
  TABLE
  DASHBOARD
  ACTION
  RELATION
  PERMISSION
  @@map("blueprint_kind")
}

enum FileVisibility {
  PRIVATE
  INTERNAL
  PUBLIC
  @@map("file_visibility")
}

enum ProjectLifecycleStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
  @@map("project_lifecycle_status")
}

enum ProjectMemberRole {
  OWNER
  MEMBER
  VIEWER
  @@map("project_member_role")
}

enum TaskPriority {
  NONE
  LOW
  MEDIUM
  HIGH
  URGENT
  @@map("task_priority")
}

enum PosMode {
  RESTAURANT
  RETAIL
  HYBRID

  @@map("pos_mode")
}

enum PosOrderStatus {
  DRAFT
  OPEN
  SENT
  PARTIALLY_SERVED
  SERVED
  PAID
  CANCELLED
  REFUNDED

  @@map("pos_order_status")
}

enum PosFulfillmentType {
  DINE_IN
  TAKEAWAY
  DELIVERY
  PICKUP

  @@map("pos_fulfillment_type")
}

enum PosSalesChannel {
  IN_STORE
  PHONE
  WEBSITE
  UBER_EATS
  RAPPI
  DIDI_FOOD
  OTHER

  @@map("pos_sales_channel")
}

enum PosTableStatus {
  AVAILABLE
  OCCUPIED
  BILL_REQUESTED
  DIRTY
  RESERVED
  DISABLED

  @@map("pos_table_status")
}

enum PosReservationStatus {
  CONFIRMED
  SEATED
  CANCELLED
  NO_SHOW

  @@map("pos_reservation_status")
}

enum PosKitchenStatus {
  PENDING
  IN_PREPARATION
  READY
  DELIVERED
  CANCELLED

  @@map("pos_kitchen_status")
}

enum PosSessionStatus {
  OPEN
  CLOSED
  CANCELLED

  @@map("pos_session_status")
}

enum PosPaymentStatus {
  PENDING
  CAPTURED
  VOIDED
  REFUNDED

  @@map("pos_payment_status")
}

enum PosExternalProvider {
  UBER_EATS
  RAPPI
  DIDI_FOOD
  WEBSITE
  OTHER

  @@map("pos_external_provider")
}

model AtlasModule {
  id String @id @default(uuid(7)) @db.Uuid
  key            String   @unique
  name           String
  description    String?
  version        String
  kind           ModuleKind @default(FEATURE)
  status         ModuleStatus @default(INSTALLED)
  core           Boolean  @default(false)
  uninstallable  Boolean  @default(true)
  enabled        Boolean  @default(true)
  manifest       Json
  lifecycleConfig Json? @map("lifecycle_config")
  installedAt DateTime @default(now()) @map("installed_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  hasBundle  Boolean  @default(false) @map("has_bundle")
  bundleHash String?  @map("bundle_hash")

  dependencies   ModuleDependency[] @relation("ModuleDependencies")
  requiredBy     ModuleDependency[] @relation("RequiredByModules")
  blueprints     Blueprint[]
  permissions    Permission[]

  @@index([status, enabled])
  @@map("atlas_module")
}

model ModuleDependency {
  id String @id @default(uuid(7)) @db.Uuid
  moduleId String @db.Uuid @map("module_id")
  dependencyId String @db.Uuid @map("dependency_id")
  versionRange String? @map("version_range")
  optional       Boolean @default(false)

  module         AtlasModule @relation("ModuleDependencies", fields: [moduleId], references: [id], onDelete: Cascade)
  dependency     AtlasModule @relation("RequiredByModules", fields: [dependencyId], references: [id], onDelete: Restrict)

  @@unique([moduleId, dependencyId])
  @@map("module_dependency")
}

model Blueprint {
  id String @id @default(uuid(7)) @db.Uuid
  key         String @unique
  moduleId String @db.Uuid @map("module_id")
  kind        BlueprintKind
  version     String
  schema      Json
  enabled     Boolean @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  module      AtlasModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@index([moduleId])
  @@index([enabled])
  @@map("blueprint")
}

model AtlasModel {
  id String @id @default(uuid(7)) @db.Uuid
  moduleKey String @map("module_key")
  name          String @unique
  tableName String @unique @map("table_name")
  label         String
  pluralLabel String? @map("plural_label")
  companyScoped Boolean @default(true) @map("company_scoped")
  schema        Json
  enabled       Boolean @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  fields        AtlasField[]
  views         AtlasView[]

  @@index([moduleKey])
  @@map("atlas_model")
}

model AtlasField {
  id String @id @default(uuid(7)) @db.Uuid
  modelId String @db.Uuid @map("model_id")
  name         String
  label        String
  type         String
  required     Boolean @default(false)
  readonly     Boolean @default(false)
  defaultValue Json? @map("default_value")
  options      Json?
  relation     Json?
  validation   Json?
  order        Int @default(0)

  model        AtlasModel @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@unique([modelId, name])
  @@map("atlas_field")
}

model AtlasView {
  id String @id @default(uuid(7)) @db.Uuid
  moduleKey String @map("module_key")
  key        String @unique
  modelName String? @map("model_name")
  type       String
  title      String?
  schema     Json
  enabled    Boolean @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  model      AtlasModel? @relation(fields: [modelName], references: [name], onDelete: SetNull, onUpdate: Cascade)

  @@index([moduleKey])
  @@index([modelName])
  @@map("atlas_view")
}

model ModuleMigration {
  id String @id @default(uuid(7)) @db.Uuid
  moduleKey String @map("module_key")
  filename  String
  checksum  String
  appliedAt DateTime @default(now()) @map("applied_at")

  @@unique([moduleKey, filename])
  @@map("module_migration")
}

model Company {
  id String @id @default(uuid(7)) @db.Uuid
  name           String
  slug           String          @unique
  legalName String? @map("legal_name")
  rfc            String?
  companyType String? @map("company_type")
  companyTypeName String? @map("company_type_name")
  industryKey String? @map("industry_key")
  industryName String? @map("industry_name")
  companySize String? @map("company_size")
  contactEmail String? @map("contact_email")
  phone          String?
  website        String?
  country        String?
  state          String?
  city           String?
  colony         String?
  street         String?
  extNumber String? @map("ext_number")
  intNumber String? @map("int_number")
  postalCode String? @map("postal_code")
  enabled        Boolean         @default(true)
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  memberships    Membership[]
  brandingConfig BrandingConfig?

  hrEmployees    HrEmployee[]
  hrDepartments  HrDepartment[]
  hrJobTitles    HrJobTitle[]

  invCategories   InvCategory[]    @relation("CompanyInvCategories")
  invBrands       InvBrand[]       @relation("CompanyInvBrands")
  invLocations    InvLocation[]    @relation("CompanyInvLocations")
  invItems        InvItem[]        @relation("CompanyInvItems")
  invCustomFields InvCustomField[] @relation("CompanyInvCustomFields")

  @@map("company")
}

model UserProfile {
  id String @id @default(uuid(7)) @db.Uuid
  authUserId String @unique @db.Uuid @map("auth_user_id")
  displayName String @map("display_name")
  firstName String   @default("") @map("first_name")
  lastName String   @default("") @map("last_name")
  email        String   @unique
  avatarFileId String? @db.Uuid @map("avatar_file_id")
  birthDate DateTime? @map("birth_date")
  gender       String?
  phone        String?
  country      String?
  state        String?
  city         String?
  colony       String?
  street       String?
  extNumber String? @map("ext_number")
  intNumber String? @map("int_number")
  postalCode String? @map("postal_code")
  bio          String?
  availableForChat Boolean @default(false) @map("available_for_chat")
  enabled      Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  memberships  Membership[]
  auditLogs    AuditLog[]
  activities   Activity[]
  notifications Notification[]
  pushSubscriptions PushSubscription[]
  notificationPreferences NotificationPreference[]

  hrEmployee HrEmployee?
  tablePreferences UserTablePreference[]
  preferences  UserPreference[]

  googleCalendarConnection GoogleCalendarConnection?
  calendarOwner          CalendarCalendar[]       @relation("CalendarOwner")
  calendarShares         CalendarShare[]          @relation("CalendarShareUser")
  calendarAttendees      CalendarEventAttendee[]  @relation("CalendarAttendee")
  calendarReminders      CalendarReminder[]       @relation("CalendarReminder")
  calendarNotifications  CalendarNotification[]   @relation("CalendarNotificationUser")

  projectsOwned      Project[]       @relation("ProjectOwner")
  projectMemberships ProjectMember[] @relation("ProjectMemberUser")
  tasksAssigned      Task[]          @relation("TaskAssignee")
  tasksCreated         Task[]                @relation("TaskCreator")
  projectTaskAssignees ProjectTaskAssignee[] @relation("TaskAssigneeUser")
  invAssignedBy   InvAssignment[]      @relation("UserInvAssignments")
  createdInvItems InvItem[]            @relation("UserCreatedInvItems")

  entityComments  EntityComment[]         @relation("UserEntityComments")
  entityMentions  EntityCommentMention[]  @relation("UserEntityMentions")
  entityReactions EntityCommentReaction[] @relation("UserEntityReactions")

  @@map("user_profile")
}

model UserTablePreference {
  id String @id @default(uuid(7)) @db.Uuid
  userId String @db.Uuid @map("user_id")
  tableKey String @map("table_key")
  config    Json
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  user      UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tableKey])
  @@index([userId])
  @@map("user_table_preference")
}

model Membership {
  id String @id @default(uuid(7)) @db.Uuid
  companyId String @db.Uuid @map("company_id")
  userId String @db.Uuid @map("user_id")
  roleId String? @db.Uuid @map("role_id")
  enabled     Boolean @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user        UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        Role? @relation(fields: [roleId], references: [id], onDelete: SetNull)

  @@unique([companyId, userId])
  @@index([userId, enabled])
  @@index([companyId])
  @@map("membership")
}

model Role {
  id String @id @default(uuid(7)) @db.Uuid
  key         String @unique
  name        String
  description String?
  system      Boolean @default(false)
  enabled     Boolean @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  memberships Membership[]
  permissions RolePermission[]
  @@map("role")
}

model Permission {
  id String @id @default(uuid(7)) @db.Uuid
  key         String @unique
  name        String
  moduleId String? @db.Uuid @map("module_id")
  moduleKey String? @map("module_key")
  description String?
  active      Boolean @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  module      AtlasModule? @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  roles       RolePermission[]

  @@index([moduleId])
  @@index([active])
  @@map("permission")
}

model RolePermission {
  id String @id @default(uuid(7)) @db.Uuid
  roleId String @db.Uuid @map("role_id")
  permissionId String @db.Uuid @map("permission_id")

  role          Role @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission    Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permission")
}

model FileAsset {
  id String @id @default(uuid(7)) @db.Uuid
  bucket        String
  objectKey String @map("object_key")
  originalName String @map("original_name")
  mimeType String @map("mime_type")
  sizeBytes Int @map("size_bytes")
  checksum      String?
  visibility    FileVisibility @default(PRIVATE)
  moduleKey String? @map("module_key")
  entityType String? @map("entity_type")
  entityId String? @db.Uuid @map("entity_id")
  uploadedById String? @db.Uuid @map("uploaded_by_id")
  metadata      Json?
  enabled       Boolean @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  hrProfileEmployees HrEmployee[] @relation("HrEmployeeProfileImage")
  calendarFiles      CalendarEventFile[]
  invItemFiles       InvItemFile[] @relation("FileAssetInvItems")
  generatedDocuments GeneratedDocument[]

  @@index([moduleKey, entityType, entityId])
  @@map("file_asset")
}

model AuditLog {
  id String @id @default(uuid(7)) @db.Uuid
  actorId String? @db.Uuid @map("actor_id")
  moduleKey String? @map("module_key")
  entityType String? @map("entity_type")
  entityId String? @db.Uuid @map("entity_id")
  action      String
  before      Json?
  after       Json?
  metadata    Json?
  createdAt DateTime @default(now()) @map("created_at")

  actor       UserProfile? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([moduleKey, entityType, entityId])
  @@index([createdAt])
  @@map("audit_log")
}

model Activity {
  id         String   @id @default(uuid(7)) @db.Uuid
  companyId  String   @db.Uuid @map("company_id")
  actorId    String?  @db.Uuid @map("actor_id")
  type       String
  entityType String?  @map("entity_type")
  entityId   String?  @db.Uuid @map("entity_id")
  summary    String
  payload    Json?
  link       String?
  severity   String   @default("info")
  source     String   @default("explicit")
  createdAt  DateTime @default(now()) @map("created_at")

  actor      UserProfile? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt(sort: Desc)])
  @@index([companyId, entityType, entityId, createdAt(sort: Desc)])
  @@index([companyId, type, createdAt(sort: Desc)])
  @@index([companyId, actorId, createdAt(sort: Desc)])
  @@map("activity")
}

model Contact {
  id String @id @default(uuid(7)) @db.Uuid
  companyId String? @db.Uuid @map("company_id")
  type        String
  name        String
  legalName String? @map("legal_name")
  email       String?
  phone       String?
  taxId String? @map("tax_id")
  notesMarkdown String? @map("notes_markdown")
  metadata    Json?
  enabled     Boolean @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([type])
  @@index([name])
  @@index([companyId, enabled])
  @@map("contact")
}

model HrEmployee {
  id String @id @default(uuid(7)) @db.Uuid
  companyId String @db.Uuid @map("company_id")
  userProfileId String? @unique @db.Uuid @map("user_profile_id")
  supervisorEmployeeId String? @db.Uuid @map("supervisor_employee_id")
  departmentId String? @db.Uuid @map("department_id")
  jobTitleId String? @db.Uuid @map("job_title_id")
  profileImageFileId String? @db.Uuid @map("profile_image_file_id")
  employeeCode String? @map("employee_code")
  firstName String @map("first_name")
  lastName String @map("last_name")
  workEmail String? @map("work_email")
  personalEmail String? @map("personal_email")
  phone          String?
  emergencyContactName String? @map("emergency_contact_name")
  emergencyContactPhone String? @map("emergency_contact_phone")
  jobTitle String? @map("job_title")
  department     String?
  managerName String? @map("manager_name")
  employmentType String? @map("employment_type")
  workLocation String? @map("work_location")
  hireDate DateTime? @map("hire_date")
  terminationDate DateTime? @map("termination_date")
  status         String   @default("active")
  notesMarkdown String? @map("notes_markdown")
  metadata       Json?
  enabled        Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  company        Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userProfile    UserProfile? @relation(fields: [userProfileId], references: [id], onDelete: SetNull)
  supervisor     HrEmployee? @relation("HrEmployeeSupervisor", fields: [supervisorEmployeeId], references: [id], onDelete: SetNull)
  reportees      HrEmployee[] @relation("HrEmployeeSupervisor")
  departmentRef  HrDepartment? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  jobTitleRef    HrJobTitle? @relation(fields: [jobTitleId], references: [id], onDelete: SetNull)
  profileImageFile FileAsset? @relation("HrEmployeeProfileImage", fields: [profileImageFileId], references: [id], onDelete: SetNull)

  assignedInvItems InvItem[]       @relation("EmployeeAssignedItems")
  invAssignments   InvAssignment[] @relation("EmployeeInvAssignments")

  @@index([companyId, enabled])
  @@index([companyId, lastName, firstName])
  @@index([companyId, supervisorEmployeeId])
  @@index([companyId, departmentId])
  @@index([companyId, jobTitleId])
  @@map("hr_employee")
}

model HrDepartment {
  id String @id @default(uuid(7)) @db.Uuid
  companyId String @db.Uuid @map("company_id")
  name        String
  description String?
  enabled     Boolean @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employees   HrEmployee[] @relation()

  @@unique([companyId, name])
  @@index([companyId, enabled])
  @@map("hr_department")
}

model HrJobTitle {
  id String @id @default(uuid(7)) @db.Uuid
  companyId String @db.Uuid @map("company_id")
  name        String
  description String?
  enabled     Boolean @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employees   HrEmployee[] @relation()

  @@unique([companyId, name])
  @@index([companyId, enabled])
  @@map("hr_job_title")
}

model InstanceConfig {
  id String @id @default(uuid(7)) @db.Uuid
  key       String   @unique
  value     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  @@map("instance_config")
}

model BrandingConfig {
  id String @id @default(uuid(7)) @db.Uuid
  companyId String @unique @db.Uuid @map("company_id")
  primaryColor String @map("primary_color")
  logoFileId String? @db.Uuid @map("logo_file_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  @@map("branding_config")
}

model Notification {
  id String @id @default(uuid(7)) @db.Uuid
  userId String @db.Uuid @map("user_id")
  companyId String? @db.Uuid @map("company_id")
  kind      String    @default("info")
  eventType String @default("system.general") @map("event_type")
  sourceType String? @map("source_type")
  sourceId String? @map("source_id")
  sourceActivityId String? @db.Uuid @map("source_activity_id")
  priority String @default("medium")
  title     String
  body      String?
  link      String?
  metadata  Json?
  dedupeKey String? @map("dedupe_key")
  expiresAt DateTime? @map("expires_at")
  readAt DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user      UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries NotificationDelivery[]

  @@index([userId, readAt])
  @@index([companyId, createdAt(sort: Desc)])
  @@index([userId, priority, createdAt(sort: Desc)])
  @@index([eventType, createdAt(sort: Desc)])
  @@index([dedupeKey])
  @@index([createdAt])
  @@map("notification")
}

model NotificationDelivery {
  id String @id @default(uuid(7)) @db.Uuid
  notificationId String @db.Uuid @map("notification_id")
  channel String
  status String @default("queued")
  attempts Int @default(0)
  lastError String? @map("last_error")
  sentAt DateTime? @map("sent_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@index([notificationId])
  @@index([channel, status, createdAt])
  @@map("notification_delivery")
}

model PushSubscription {
  id String @id @default(uuid(7)) @db.Uuid
  userId String @db.Uuid @map("user_id")
  companyId String? @db.Uuid @map("company_id")
  endpoint String @unique
  p256dh String
  auth String
  deviceLabel String? @map("device_label")
  userAgent String? @map("user_agent")
  enabled Boolean @default(true)
  lastSeenAt DateTime? @map("last_seen_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, enabled])
  @@index([companyId, enabled])
  @@map("push_subscription")
}

model NotificationPreference {
  id String @id @default(uuid(7)) @db.Uuid
  userId String @db.Uuid @map("user_id")
  eventType String @map("event_type")
  inAppEnabled Boolean @default(true) @map("in_app_enabled")
  emailEnabled Boolean @default(false) @map("email_enabled")
  pushEnabled Boolean @default(false) @map("push_enabled")
  muteUntil DateTime? @map("mute_until")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventType])
  @@index([userId])
  @@map("notification_preference")
}

model UserPreference {
  id String @id @default(uuid(7)) @db.Uuid
  userId String @db.Uuid @map("user_id")
  key       String
  value     Json
  updatedAt DateTime    @updatedAt @map("updated_at")

  user      UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId])
  @@map("user_preference")
}

// ─── atlas.website ────────────────────────────────────────────────────────────

model WebsiteSite {
  id                     String    @id @default(uuid(7)) @db.Uuid
  companyId              String    @db.Uuid @map("company_id")
  name                   String
  domain                 String?
  defaultLocale          String    @default("es") @map("default_locale")
  status                 String    @default("draft")
  siteType               String    @default("website") @map("site_type")
  homepagePageId         String?   @db.Uuid @map("homepage_page_id")
  themeId                String?   @db.Uuid @map("theme_id")
  settings               Json?
  seoDefaults            Json?     @map("seo_defaults")
  sourceType             String    @default("builder") @map("source_type")
  distUploadedAt         DateTime? @map("dist_uploaded_at")
  distFileCount          Int?      @map("dist_file_count")
  distHasPrerender       Boolean?  @map("dist_has_prerender")
  distManifest           Json?     @map("dist_manifest")
  stripePublishableKey   String?   @map("stripe_publishable_key")
  stripeSecretKey        String?   @map("stripe_secret_key")
  stripeCurrency         String    @default("usd") @map("stripe_currency")
  stripeSuccessMessage   String?   @map("stripe_success_message")
  analyticsMode          String    @default("off") @map("analytics_mode")
