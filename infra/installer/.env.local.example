# Atlas ERP installer - local Supabase mode
# Copy this file to .env.local.
#
# Recommended: run setup-local.ps1 to auto-generate .env.local.
# It starts Supabase via npx and writes all values automatically.

NODE_ENV=production
ATLAS_API_PORT=4010
ATLAS_TIME_ZONE=America/Mexico_City
TZ=America/Mexico_City

# Optional image overrides for local runtime.
# Defaults in docker-compose.yml:
# - raulbellosom/atlaserp:api-latest
# - raulbellosom/atlaserp:worker-latest
# - raulbellosom/atlaserp:web-latest
# ATLAS_API_LOCAL_IMAGE=raulbellosom/atlaserp:api-latest
# ATLAS_WORKER_LOCAL_IMAGE=raulbellosom/atlaserp:worker-latest
# ATLAS_WEB_LOCAL_IMAGE=raulbellosom/atlaserp:web-latest

# Local Supabase exposed by CLI on host machine.
# host.docker.internal is injected via extra_hosts in compose.
SUPABASE_URL=http://host.docker.internal:54321
SUPABASE_ANON_KEY=<LOCAL_SUPABASE_ANON_KEY>
SUPABASE_SERVICE_ROLE_KEY=<LOCAL_SUPABASE_SERVICE_ROLE_KEY>
# Source:
# - Run `supabase start`
# - Then read values from `supabase status -o env`
SUPABASE_JWT_SECRET=<LOCAL_SUPABASE_JWT_SECRET>

# Atlas API secret.
# In Atlas today, use the same value as SUPABASE_JWT_SECRET unless you
# intentionally separate both token systems.
JWT_SECRET=<YOUR_ATLAS_API_JWT_SECRET>

# Local Postgres from Supabase CLI
DATABASE_URL=postgresql://postgres:postgres@host.docker.internal:54322/postgres
DIRECT_URL=postgresql://postgres:postgres@host.docker.internal:54322/postgres

# Frontend public vars for local mode
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=<LOCAL_SUPABASE_ANON_KEY>
VITE_ATLAS_API_URL=http://localhost:4010

# ── Public deployment URLs ────────────────────────────────────────────────────
# For VPS + Nginx deployments, set these so the browser can reach the public API.
# CORS_ORIGIN: public URL of the Atlas web app (frontend).
# ATLAS_API_URL: public URL of the Atlas API. Pass as env var when running setup:
#   ATLAS_API_URL=https://api.yourdomain.com node setup-local.mjs
CORS_ORIGIN=http://localhost:5173

# ── Google Calendar integration (optional) ───────────────────────────────────
# Register OAuth credentials at: https://console.cloud.google.com → APIs & Services → Credentials
# Leave placeholders to disable Google Calendar sync.
# setup-local.mjs auto-generates GOOGLE_OAUTH_ENCRYPTION_KEY on first run and
# preserves all four values across subsequent re-runs (Supabase refresh does not wipe them).
GOOGLE_OAUTH_CLIENT_ID=<YOUR_GOOGLE_OAUTH_CLIENT_ID>
GOOGLE_OAUTH_CLIENT_SECRET=<YOUR_GOOGLE_OAUTH_CLIENT_SECRET>
GOOGLE_OAUTH_REDIRECT_URI=https://your-atlas-domain.com/app/google/calendar/callback
# Generate manually: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Or let setup-local.mjs generate it automatically.
GOOGLE_OAUTH_ENCRYPTION_KEY=<AUTO_GENERATED_BY_SETUP>
