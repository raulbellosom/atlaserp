# Atlas ERP installer - external Supabase mode
# Copy this file to .env.external and fill placeholders.

NODE_ENV=production
ATLAS_API_PORT=4010
ATLAS_TIME_ZONE=America/Mexico_City
TZ=America/Mexico_City

# External Supabase endpoint and keys
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=<YOUR_SUPABASE_ANON_KEY>
SUPABASE_SERVICE_ROLE_KEY=<YOUR_SUPABASE_SERVICE_ROLE_KEY>
# Source:
# - Supabase Cloud: Project Settings -> API -> JWT secret
# - Supabase self-hosted: value named JWT_SECRET in Supabase .env
SUPABASE_JWT_SECRET=<YOUR_SUPABASE_JWT_SECRET>

# Atlas API secret.
# In Atlas today, use the same value as SUPABASE_JWT_SECRET unless you
# intentionally separate both token systems.
JWT_SECRET=<YOUR_ATLAS_API_JWT_SECRET>

# Database connection used by Prisma
DATABASE_URL=postgresql://postgres:<PASSWORD>@<HOST>:5432/postgres
DIRECT_URL=postgresql://postgres:<PASSWORD>@<HOST>:5432/postgres

# Frontend public vars (if your web image was built for runtime placeholders)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=<YOUR_SUPABASE_ANON_KEY>
VITE_ATLAS_API_URL=http://localhost:4010

# ── Public deployment URLs ────────────────────────────────────────────────────
# For VPS + Nginx deployments, set these to your public domains so the browser
# can reach both the API and Supabase from the internet.
# CORS_ORIGIN: public URL of the Atlas web app (frontend).
# ATLAS_API_URL: public URL of the Atlas API, used by the web container at runtime.
CORS_ORIGIN=http://localhost:5173
ATLAS_API_URL=http://localhost:4010

# ── Google Calendar integration (optional) ───────────────────────────────────
# Register OAuth credentials at: https://console.cloud.google.com → APIs & Services → Credentials
# Leave placeholders to disable Google Calendar sync.
GOOGLE_OAUTH_CLIENT_ID=<YOUR_GOOGLE_OAUTH_CLIENT_ID>
GOOGLE_OAUTH_CLIENT_SECRET=<YOUR_GOOGLE_OAUTH_CLIENT_SECRET>
GOOGLE_OAUTH_REDIRECT_URI=https://your-atlas-domain.com/app/google/calendar/callback
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
GOOGLE_OAUTH_ENCRYPTION_KEY=<YOUR_GOOGLE_OAUTH_ENCRYPTION_KEY>
