# Atlas ERP
NODE_ENV=development
ATLAS_APP_NAME="Atlas ERP"
ATLAS_API_PORT=4010
ATLAS_API_URL=http://localhost:4010
ATLAS_DESKTOP_DEV_URL=http://localhost:5173
ATLAS_TIME_ZONE=America/Mexico_City
TZ=America/Mexico_City

# Database
# For local-lite PostgreSQL:
DATABASE_URL="postgresql://atlas:atlas@localhost:5432/atlas_erp?schema=public"
DIRECT_URL="postgresql://atlas:atlas@localhost:5432/atlas_erp?schema=public"

# Supabase self-hosted, when enabled
SUPABASE_URL=http://localhost:8000
SUPABASE_ANON_KEY=replace_me
SUPABASE_SERVICE_ROLE_KEY=replace_me

# Storage mode: supabase | minio | local
ATLAS_STORAGE_DRIVER=minio
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=atlas_minio
MINIO_SECRET_KEY=atlas_minio_secret
MINIO_BUCKET=atlas-files

# Redis optional
REDIS_URL=redis://localhost:6379

# Security
JWT_SECRET=change_me_in_production
CORS_ORIGIN=http://localhost:5173,tauri://localhost
