# Atlas ERP — Environment Variables
# Copy this file to .env and fill in real values.
# Never commit .env to version control.
#
# ─── IMPORTANT: Self-hosted Supabase ─────────────────────────────────────────
# This project connects to a dedicated self-hosted Supabase instance.
# It is NOT Supabase Cloud. The "Settings → Database" screen in Studio
# may not be available or may differ from Cloud docs.
#
# Keys and the Postgres password live on the VPS at:
#   /opt/supabase-atlaserp/supabase/docker/.env
# Copy: ANON_KEY → SUPABASE_ANON_KEY
#       SERVICE_ROLE_KEY → SUPABASE_SERVICE_ROLE_KEY
#       JWT_SECRET → SUPABASE_JWT_SECRET
#       POSTGRES_PASSWORD → used in DATABASE_URL and DIRECT_URL below
#
# PostgreSQL is exposed on port 5432 of the VPS (76.13.114.109).
# No SSH tunnel required — connect directly using the VPS public IP.
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=development
ATLAS_APP_NAME="Atlas ERP"
ATLAS_API_PORT=4010
ATLAS_TIME_ZONE=America/Mexico_City
TZ=America/Mexico_City

# ─── Supabase (define once) ──────────────────────────────────────────────────
# Source: /opt/supabase-atlaserp/supabase/docker/.env on the VPS
SUPABASE_URL=https://supabase.racoondevs.com
SUPABASE_STUDIO_URL=https://studio.supabase.racoondevs.com
SUPABASE_ANON_KEY=             # ANON_KEY from VPS .env — public, safe for frontend
SUPABASE_SERVICE_ROLE_KEY=     # SERVICE_ROLE_KEY from VPS .env — SECRET, API/worker only
SUPABASE_JWT_SECRET=           # JWT_SECRET from VPS .env — used by Supabase to sign tokens

# ─── Prisma / PostgreSQL ─────────────────────────────────────────────────────
# Replace <POSTGRES_PASSWORD> with POSTGRES_PASSWORD from VPS .env.
DATABASE_URL=postgresql://postgres:<POSTGRES_PASSWORD>@76.13.114.109:5432/postgres
DIRECT_URL=postgresql://postgres:<POSTGRES_PASSWORD>@76.13.114.109:5432/postgres

# ─── Atlas API ───────────────────────────────────────────────────────────────
JWT_SECRET=                    # Atlas API own secret — generate a random 64-char string
CORS_ORIGIN=http://localhost:5173,tauri://localhost

# ─── Vite aliases (VITE_ prefix required by Vite for frontend access) ────────
# Only SUPABASE_URL and SUPABASE_ANON_KEY may be aliased for the frontend.
# NEVER add VITE_ aliases for SERVICE_ROLE_KEY, SUPABASE_JWT_SECRET, JWT_SECRET, or DATABASE_URL.
VITE_SUPABASE_URL=${SUPABASE_URL}
VITE_SUPABASE_ANON_KEY=${SUPABASE_ANON_KEY}
VITE_ATLAS_API_URL=http://localhost:4010
