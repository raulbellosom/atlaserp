{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-capability",
  "description": "Capability for the main Atlas ERP window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:default",
    "sql:default",
    "sql:allow-execute",
    "store:allow-load",
    "store:allow-get",
    "store:allow-set",
    "store:allow-save"
  ]
}
