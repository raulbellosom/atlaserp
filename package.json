{
  "name": "atlas-erp-starter",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "start": "bash scripts/start-dev.sh",
    "dev": "concurrently --kill-others-on-fail -n api,web,worker -c cyan,magenta,yellow \"pnpm dev:api\" \"pnpm dev:frontend\" \"pnpm dev:worker\"",
    "dev:api": "pnpm --filter @atlas/api dev",
    "dev:frontend": "pnpm --filter @atlas/desktop dev:web",
    "dev:worker": "pnpm --filter @atlas/worker dev",
    "dev:tauri": "concurrently --kill-others-on-fail -n api,tauri,worker -c cyan,magenta,yellow \"pnpm dev:api\" \"pnpm --filter @atlas/desktop dev\" \"pnpm dev:worker\"",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "db:migrate": "prisma migrate deploy && prisma generate",
    "db:generate": "prisma generate",
    "db:seed": "node prisma/seed.js",
    "db:studio": "prisma studio --port 5555 --browser none",
    "db:reset": "prisma migrate reset --force && node prisma/seed.js",
    "db:fresh": "prisma migrate deploy && prisma generate && node prisma/seed.js",
    "setup": "pnpm install && pnpm db:generate && pnpm db:migrate && pnpm db:seed",
    "icons:generate": "node scripts/gen-icons.mjs",
    "brand:build": "node scripts/build-brand-assets.mjs",
    "rbac:verify-catalog": "node scripts/verify-permission-catalog.mjs",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio --port 5555 --browser none",
    "modules:seed": "node scripts/seed-core-modules.js",
    "check:uuid-policy": "node scripts/enforce-uuid-policy.mjs",
    "module:checksums": "node scripts/check-module-manifest-migrations.mjs",
    "module:checksums:fleet": "node scripts/check-module-manifest-migrations.mjs modules/custom/custom.fleet",
    "module:checksums:write": "node scripts/check-module-manifest-migrations.mjs modules/custom/custom.fleet --write",
    "db:advisor-equivalent": "node scripts/check-supabase-advisor-equivalent.mjs"
  },
  "dependencies": {
    "@atlas/module-engine": "workspace:*",
    "@nivo/bar": "^0.99.0",
    "@nivo/line": "^0.99.0",
    "@nivo/pie": "^0.99.0",
    "@prisma/adapter-pg": "^7.8.0",
    "dotenv": "^17.4.2",
    "hono": "^4.12.18",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@prisma/client": "^7.8.0",
    "concurrently": "latest",
    "prisma": "^7.8.0"
  },
  "pnpm": {
    "overrides": {
      "@prisma/client": "^7.8.0",
      "prisma": "^7.8.0"
    }
  }
}
